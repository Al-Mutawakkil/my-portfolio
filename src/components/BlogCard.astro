---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover: string;
  readTime: number;
}

const { slug, title, description, date, tags, cover, readTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-cover">
    <img src={cover} alt={title} loading="lazy" />
  </div>
  <div class="blog-card-body">
    {tags[0] && <span class="blog-card-tag">{tags[0]}</span>}
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-desc">{description}</p>
    <div class="blog-card-meta">
      <span>{formattedDate}</span>
      <span>·</span>
      <span>{readTime} min read</span>
    </div>
  </div>
</a>
