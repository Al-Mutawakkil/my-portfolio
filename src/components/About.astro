---
import TextType from './TextType.tsx';
import FlipCard from './FlipCard.tsx';
---

<section id="about">
  <div class="about-inner reveal">
    <div class="about-text">
      <span class="section-tag tag-about">👋 About</span>
      <h2 class="section-heading">
        <TextType
          client:load
          texts={["Hey, I'm Adib", "I build for the web", "I ship real things"]}
          typingSpeed={40}
          deletingSpeed={25}
          pauseDuration={1500}
          showCursor
          cursorCharacter="_"
          cursorBlinkDuration={0.5}
        />
      </h2>
      <p class="about-bio">
        I'm Thufail Adib Al Mutawakkil, but I usually go by Adib. I'm a self-taught developer from Cikarang, Indonesia. I started breaking things in code back in high school (2019), out of curiosity and a lot of Stack Overflow. By 2022 I was doing it professionally, and I haven't looked back since.
      </p>
      <p class="about-bio">
        I build websites, web apps, dashboards, internal tools, and mobile apps for startups and small businesses. I work fast, keep things simple, and care more about shipping something real than perfecting something that never launches.
      </p>
      <p class="about-bio">
        Outside of work, I run, cycle, hike, and solo travel more than I probably should. Usually just to feel out a new city and find a good coffee shop to work from. Big fan of Indonesian food, trying to get into padel, and always up for a good movie recommendation.
      </p>
      <a href="mailto:thufails505@gmail.com" class="btn btn-primary">Get in touch →</a>
    </div>
    <FlipCard client:load />
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .about-bio {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-bio:last-of-type {
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
