---
import StackIcons from './StackIcons.tsx';
import TextType from './TextType.tsx';

const experience = [
  {
    company: 'Etalas',
    companyUrl: 'https://etalas.com',
    role: 'Full-Stack Product Engineer',
    start: 'Jul 2022',
    end: 'Present',
    current: true,
    description: 'Shipping full-stack web, mobile, and Go backend work across fintech, hospitality, and booking platforms.',
  },
] satisfies {
  company: string;
  companyUrl?: string;
  role: string;
  start: string;
  end: string;
  current?: boolean;
  description: string;
}[];

const current = experience.find((e) => e.current) ?? experience[0];
const previously = experience.filter((e) => e !== current);
---

<section id="about">
  <div class="about-inner reveal">
    <div class="about-text">
      <span class="section-tag tag-about">👋 About</span>
      <h2 class="section-heading">
        <TextType
          client:load
          texts={["Hey, I'm Adib", "I build for the web", "I ship real things"]}
          typingSpeed={40}
          deletingSpeed={25}
          pauseDuration={1500}
          showCursor
          cursorCharacter="_"
          cursorBlinkDuration={0.5}
        />
      </h2>
      <p class="about-bio">
        Self-taught developer from Cikarang, Indonesia. I started breaking things in code back in high school (2019) — just curiosity and a lot of Stack Overflow. By 2022 I was doing it professionally, and I haven't looked back since.
      </p>
      <p class="about-bio">
        I build websites, apps, and SaaS tools for startups and small businesses. I work fast, keep things simple, and care more about shipping something real than perfecting something that never launches.
      </p>
      <p class="about-bio">
        Outside of work — I run, cycle, hike, and solo travel more than I probably should. Usually just to feel out a new city and find a good coffee shop to work from. Big fan of Indonesian food, trying to get into padel, and always up for a good movie recommendation.
      </p>
      <a href="mailto:thufails505@gmail.com" class="btn btn-primary">Get in touch →</a>
    </div>
    <div class="about-aside">
      <div class="about-experience">
        <div class="exp-label-row">
          <span class="stack-label">Work Experience</span>
          {current.current && (
            <span class="live-badge">
              <span class="live-dot"></span> Currently
            </span>
          )}
        </div>
        {current.companyUrl ? (
          <a href={current.companyUrl} class="hero-company" target="_blank" rel="noopener noreferrer">
            {current.company}
            <span class="hero-company-arrow" aria-hidden="true">↗</span>
          </a>
        ) : (
          <div class="hero-company">{current.company}</div>
        )}
        <div class="hero-meta">
          <span class="hero-role">{current.role}</span>
          <span class="hero-sep">·</span>
          <span class="hero-dates">{current.start} — {current.end}</span>
        </div>
        <p class="hero-desc">{current.description}</p>

        {previously.length > 0 && (
          <div class="previously">
            <div class="previously-label">Previously</div>
            {previously.map((p) => (
              <div class="prev-entry">
                <span class="prev-company">{p.company}</span>
                <span class="prev-sep">·</span>
                <span class="prev-role">{p.role}</span>
                <span class="prev-dates">{p.start} — {p.end}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="about-stack">
        <div class="stack-label">What I work with</div>
        <StackIcons client:load />
      </div>
    </div>
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .about-bio {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-bio:last-of-type {
    margin-bottom: 2rem;
  }

  .about-aside {
    padding-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .about-stack {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .stack-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    display: block;
  }

  .about-experience {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .exp-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .exp-label-row .stack-label {
    margin-bottom: 0;
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    background: rgba(255, 107, 53, 0.1);
    color: var(--coral);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--coral);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.25);
    animation: livePulse 2s ease-in-out infinite;
  }

  @keyframes livePulse {
    50% { box-shadow: 0 0 0 6px rgba(255, 107, 53, 0.08); }
  }

  .hero-company {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, var(--text) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    transition: opacity 0.2s ease;
  }

  a.hero-company:hover {
    opacity: 0.75;
  }

  .hero-company-arrow {
    font-size: 0.95rem;
    font-weight: 700;
    -webkit-text-fill-color: var(--blue);
    color: var(--blue);
    transition: transform 0.3s var(--bounce);
  }

  a.hero-company:hover .hero-company-arrow {
    transform: translate(2px, -2px);
  }

  .hero-meta {
    margin-top: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }

  .hero-role { font-weight: 600; }
  .hero-sep { color: var(--text-muted); }
  .hero-dates { color: var(--text-muted); font-weight: 500; }

  .hero-desc {
    margin-top: 1.1rem;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .previously {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px dashed rgba(0, 0, 0, 0.1);
  }

  .previously-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .prev-entry {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.82rem;
    padding: 0.35rem 0;
  }

  .prev-company { font-weight: 700; color: var(--text); }
  .prev-sep { color: var(--text-muted); }
  .prev-role { color: var(--text-muted); }
  .prev-dates {
    margin-left: auto;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
