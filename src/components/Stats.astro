    <div class="stats-content">
      <p class="stats-label">Results that speak for themselves</p>
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number">12<span class="stat-accent">+</span></div>
          <div class="stat-desc">Projects shipped</div>
        </div>
        <div class="stat-item">
          <div class="stat-number"><span class="stat-accent">$</span>2M</div>
          <div class="stat-desc">Revenue generated for clients</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">100<span class="stat-accent">%</span></div>
          <div class="stat-desc">On-time delivery rate</div>
        </div>
      </div>
    </div>
  </div>
</div>
