<div class="stats-scroll-wrapper">
  <div class="stats-section">
    <div class="stats-logo-cloud">
      <div class="stats-logo sl-1"><span>⚛️</span></div>
      <div class="stats-logo sl-2">
        <svg viewBox="0 0 24 24"><path d="M12 2L2 19.5h20L12 2zm0 4l7 12H5l7-12z"/></svg>
      </div>
      <div class="stats-logo sl-3">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
      </div>
      <div class="stats-logo sl-4"><span>🔥</span></div>
      <div class="stats-logo sl-5">
        <svg viewBox="0 0 24 24"><path d="M1.5 0h21l-1.91 21.56L11.5 24l-8.18-2.44L1.5 0zm17.09 4.49H5.91l.44 4.93h8.28l-.39 4.13-3.74 1.01-3.74-1.01-.25-2.82h-2.6l.49 5.52L11.5 19l6.36-1.75L18.59 4.49z"/></svg>
      </div>
      <div class="stats-logo sl-6"><span>📱</span></div>
      <div class="stats-logo sl-7">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c1.85 0 3.58-.5 5.07-1.38l-1.45-1.73C14.52 19.59 13.29 20 12 20c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8c0 .74-.1 1.46-.3 2.14l1.83 1.1C21.84 14.2 22 13.12 22 12c0-5.52-4.48-10-10-10z"/></svg>
      </div>
      <div class="stats-logo sl-8"><span>🎨</span></div>
      <div class="stats-logo sl-9">
        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/><path d="M2 17l10 5 10-5" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/><path d="M2 12l10 5 10-5" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/></svg>
      </div>
      <div class="stats-logo sl-10"><span>⚡</span></div>
      <div class="stats-logo sl-11">
        <svg viewBox="0 0 24 24"><path d="M17.6 11.48l1.44-4.68A1 1 0 0018.09 5.5H5.91a1 1 0 00-.95 1.3l1.44 4.68C3.16 12.56 1 15.03 1 18c0 3.31 4.03 6 9 6h4c4.97 0 9-2.69 9-6 0-2.97-2.16-5.44-5.4-6.52z"/></svg>
      </div>
      <div class="stats-logo sl-12"><span>🚀</span></div>
      <div class="stats-logo sl-13">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
      </div>
      <div class="stats-logo sl-14"><span>💎</span></div>
      <div class="stats-logo sl-15">
        <svg viewBox="0 0 24 24"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
      </div>
      <div class="stats-logo sl-16"><span>🔧</span></div>
      <div class="stats-logo sl-17">
        <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
